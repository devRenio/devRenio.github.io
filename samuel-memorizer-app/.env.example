# =============================================================================
# Samuel Memorizer — 환경 변수
# 이 파일을 .env 로 복사한 뒤 값을 채우세요. .env 는 git에 올리지 않습니다.
# 상세 가이드: docs/SETUP-가이드.md (Cloudflare부터 푸시까지)
# 기술 참고: docs/DEPLOY-BFF.md
# =============================================================================

# --- BFF 서버 전용 (VITE_ 접두사 금지 — 클라이언트 번들에 들어가면 안 됨) ---

# jbch API 발급 프로그램명 (영문)
JBCH_DEV_NAME=

# jbch 50자리 API 토큰
JBCH_TOKEN_ID=

# 쪽지 문의 수신자 깨사모 userid (BFF가 send_message toIds 로 고정 사용)
JBCH_SUPPORT_USERID=

# CORS 허용 Origin (쉼표 구분). Worker wrangler.toml [vars] 에도 동일하게 설정
# 로컬 dev 기본값: http://localhost:5173, http://127.0.0.1:5173 (플러그인 기본)
# JBCH_CORS_ORIGINS=http://localhost:5173

# --- 클라이언트 (VITE_ = 빌드 시 JS 번들에 포함됨 — 비밀값 넣지 말 것) ---

# [프로덕션 필수] Cloudflare Worker BFF URL (끝에 /api/jbch 까지)
# 예: https://samuel-jbch-bff.<account>.workers.dev/api/jbch
# 로컬 dev(npm run dev)에서는 비워 두면 /api/jbch (Vite BFF) 사용
VITE_JBCH_BFF_URL=

# 관리자 콘솔 UI 표시용 userid (쉼표 구분). 서버 권한이 아님
VITE_ADMIN_USERIDS=eunho715

# 문의 모달에 보이는 수신자 이름 (실제 발송 대상은 JBCH_SUPPORT_USERID)
VITE_JBCH_SUPPORT_LABEL=서울양천 공은호 형제

# =============================================================================
# Cloudflare Worker secret (wrangler secret put — .env 와 별도)
#   JBCH_DEV_NAME
#   JBCH_TOKEN_ID
#   JBCH_SUPPORT_USERID
# wrangler.toml [vars]:
#   JBCH_CORS_ORIGINS = "https://devrenio.github.io"
# =============================================================================
