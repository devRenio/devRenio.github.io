# Firebase Authentication (GitHub Pages + 무료 Spark 플랜)
# Firebase Console → 프로젝트 설정 → 앱 → SDK 구성 값을 입력하세요.
# Authentication → Sign-in method → 이메일/비밀번호 활성화
# Authentication → Templates → Email address verification (인증 메일 문구·발신자 표시)
#   → 스팸함 분류 완화: Blaze 플랜 + 커스텀 SMTP/도메인(DKIM·SPF) 또는 템플릿·발신자명 정비
#   → 무료 Spark는 Firebase 기본 발송(noreply@…)이라 스팸함 가능 — 앱에서 안내 문구 표시
# Authentication → Settings → Authorized domains → devrenio.github.io 추가
# Firestore Database → 데이터베이스 만들기 (테스트/프로덕션)
#   → users/{uid} 문서에 이름·교회명·진행(progress) 저장
# Firestore Rules: samuel-memorizer-app/firestore.rules 배포
#   → isAdmin() 이메일 목록을 VITE_ADMIN_EMAILS와 동일하게 설정

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# 관리자 이메일(쉼표 구분). firestore.rules isAdmin()에도 동일 이메일 추가 필요
VITE_ADMIN_EMAILS=
